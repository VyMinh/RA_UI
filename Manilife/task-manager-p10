                    success: function(response) {
                        const hasPrimary = !!response.has_primary_keywords;
                        const hasSecondary = !!response.has_secondary_keywords;
                        const hasExclude = !!response.has_exclude_keywords;
                        const isSourceOwn = !!response.is_source_own;
                        const hasBypassKeyword = !!response.has_bypass_keyword;

                        window.currentValidationState = {
                            mentionId: mentionId,
                            topicId: topicId || '',
                            hasPrimary: hasPrimary,
                            hasSecondary: hasSecondary,
                            hasExclude: hasExclude,
                            isSourceOwn: isSourceOwn,
                            hasBypassKeyword: hasBypassKeyword,
