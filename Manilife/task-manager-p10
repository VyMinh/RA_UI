    <script>
        $(document).ready(function() {
            // Initialize Date Pickers for Start/End Date
            $('.input-stats-start-date, .input-stats-end-date').daterangepicker({
                singleDatePicker: true,
                autoUpdateInput: false,
                locale: {
                    cancelLabel: 'Clear',
                    format: 'DD/MM/YYYY'
                }
            });

            $('.input-stats-start-date, .input-stats-end-date').on('apply.daterangepicker', function(ev, picker) {
                $(this).val(picker.startDate.format('DD/MM/YYYY'));
            });

            $('.input-stats-start-date, .input-stats-end-date').on('cancel.daterangepicker', function(ev, picker) {
                $(this).val('');
            });

            function loadMediaTypeStats() {
                $('#customField3StatsContent').html('<div class="text-center" style="padding: 20px;">Loading...</div>');
                
                const startDate = $('.input-stats-start-date').val();
                const endDate = $('.input-stats-end-date').val();
                const topicId = $('#stats-topic-filter').val();

                $.ajax({
                    url: 'https://s1.socialyze.asia/super-admin/systems-manager/task-manager/custom-field-3-statistics',
                    type: 'GET',
                    data: {
                        start_date: startDate,
                        end_date: endDate,
                        topic_id: topicId
                    },
                    success: function(response) {
                        if (response.status === 'success' && response.data) {
                            let html = '<div class="table-responsive"><table class="table table-bordered table-hover">';
                            html += '<thead style="background-color: #f5f5f5;"><tr><th>Media Type</th><th>Count</th><th>Percentage</th></tr></thead><tbody>';
                            
                            if (response.data.length === 0) {
                                html += '<tr><td colspan="3" class="text-center">No data found</td></tr>';
                            } else {
                                response.data.forEach(function(item) {
                                    html += '<tr><td>' + item.name + '</td><td>' + item.count + '</td><td>' + item.percentage + '%</td></tr>';
                                });
                            }
                            
                            html += '</tbody></table></div>';
                            html += '<div class="text-right" style="margin-top: 10px;"><strong>Total: ' + response.total + '</strong></div>';
                            
                            $('#customField3StatsContent').html(html);
                        } else {
                            $('#customField3StatsContent').html('<div class="text-center" style="padding: 20px;">' + (response.message || 'Error loading data') + '</div>');
                        }
                    },
                    error: function() {
                        $('#customField3StatsContent').html('<div class="text-center" style="padding: 20px;">Error loading data</div>');
                    }
                });
            }

            $('#view-custom-field-3-stats-link').click(function() {
                $('#customField3StatsModal').modal('show');
                // Reset filters on open if desired, or keep them. Let's keep them but maybe reload?
                // Or just reload with current inputs.
                loadMediaTypeStats();
            });

            $('#apply-stats-filter').click(function() {
                loadMediaTypeStats();
            });
        });
    </script>
